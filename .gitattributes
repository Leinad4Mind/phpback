# Normalize line endings to LF in the repository for all text files.
* text=auto eol=lf

*.php   text eol=lf
*.css   text eol=lf
*.js    text eol=lf
*.html  text eol=lf
*.md    text eol=lf
*.json  text eol=lf
*.env   text eol=lf
*.sql   text eol=lf

# Binary assets — never normalize.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.eot   binary
*.ttf   binary
*.woff  binary
*.woff2 binary
*.pdf   binary
*.sqlite binary
